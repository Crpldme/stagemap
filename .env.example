# ════════════════════════════════════════
# StageMap — Environment Variables
# Copy to .env.local and fill in values
# ════════════════════════════════════════

# ── Supabase (required) ──────────────────
# Get from: https://supabase.com → Project → Settings → API
REACT_APP_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ── Anthropic AI (required for Tour Planner) ─
# Get from: https://console.anthropic.com → API Keys
REACT_APP_ANTHROPIC_KEY=sk-ant-api03-...

# ── Mapbox (required for real map) ───────
# Get from: https://account.mapbox.com → Tokens
REACT_APP_MAPBOX_TOKEN=pk.eyJ1IjoieW91...

# ── Stripe (required for payments) ───────
# Get from: https://dashboard.stripe.com → Developers → API Keys
REACT_APP_STRIPE_PUBLIC_KEY=pk_live_...
# For Stripe webhooks (server-side, not needed for frontend):
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Price IDs ─────────────────────
# Create in Stripe Dashboard → Products
REACT_APP_STRIPE_PRICE_MONTHLY=price_...
REACT_APP_STRIPE_PRICE_ANNUAL=price_...
REACT_APP_STRIPE_PRICE_LOCAL=price_...
REACT_APP_STRIPE_PRICE_BOOST=price_...
REACT_APP_STRIPE_PRICE_PRO=price_...

# ── App config ───────────────────────────
REACT_APP_URL=https://stagemap.io
REACT_APP_ENV=production
